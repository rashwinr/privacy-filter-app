# Env & secrets
.env
*.env.local

# GCP / GCS credentials (never commit service account keys)
*service-account*.json
gcp-*.json
gcs-*.json

# SSL / TLS certificates (Cloud SQL client certs)
*.pem

# Data (uploads + redacted outputs)
data/uploads/*
data/redacted/*
!data/uploads/.gitkeep
!data/redacted/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# Model cache (downloaded weights)
.cache/
hf_cache/

# IDE
.idea/
.vscode/
.DS_Store

# Build / Docker
*.log
*.pid

# Test artifacts
.coverage
.pytest_cache/
