# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0

# ── DICOM de-identification ───────────────────────────────────────────────────
# Number of pixel rows to black out at the top of the DICOM image to remove
# burned-in patient annotations (text overlaid on the scan).
# Default: 100 (matches original deidentification.py script).
DICOM_PIXEL_REDACT_ROWS=100

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_NAME=openai/privacy-filter
MODEL_DEVICE=cpu                 # cpu | cuda | mps
MODEL_AGGREGATION=simple         # simple | first | average | max

# ── Storage backend ───────────────────────────────────────────────────────────
# Set STORAGE_BACKEND=gcs to enable Google Cloud Storage.
# Uploaded files → gs://tanuh-bcd-bucket/privacy-app/uploads/<job_id>__<filename>
# Redacted files → gs://tanuh-bcd-bucket/privacy-app/redacted/<job_id>__redacted.<ext>
STORAGE_BACKEND=gcs
LOCAL_DATA_DIR=./data

# GCS target (matches tanuh-bcd-bucket / privacy-app folder)
GCS_BUCKET=tanuh-bcd-bucket
GCS_PREFIX=privacy-app

# ── GCS Authentication ────────────────────────────────────────────────────────
# Priority 1: dedicated GCS service account (tanuh-bcd-application2)
# Copy gcs-service-account.json from NHCX_HACKATHON and set path here.
GCS_CREDENTIALS_JSON=gcs-service-account.json

# Priority 2: shared / Vertex SA (fallback if GCS_CREDENTIALS_JSON not found)
# Copy gcp-service-account.json from NHCX_HACKATHON and set path here.
GOOGLE_APPLICATION_CREDENTIALS=gcp-service-account.json

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
PROJECT_ID=tanuh-bcd-questionnaire
REGION=global
ENDPOINT=aiplatform.googleapis.com

# ── Auth (demo tokens + optional Keycloak) ───────────────────────────────────
# SECRET_KEY signs demo JWT tokens (HS256). Keep this secret and rotate it
# if you need to invalidate all previously issued demo tokens.
SECRET_KEY=<your-secret-key>

# Demo token validity (default: 7 days). Lower for tighter access control.
DEMO_TOKEN_EXPIRY_DAYS=7

# Set to "false" to disable auth enforcement entirely (local dev / CI).
KEYCLOAK_AUTH_ENABLED=true

# ── Keycloak (optional, production only) ──────────────────────────────────────
# Leave blank to accept only self-issued demo tokens.
# KEYCLOAK_REALM_URL=https://keycloak.tanuh.org/realms/tanuh
# KEYCLOAK_CLIENT_ID=privacy-filter
# KEYCLOAK_AUDIENCE=privacy-filter

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
