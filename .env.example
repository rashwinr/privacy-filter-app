# Server
PORT=8080
HOST=0.0.0.0

# Model
MODEL_NAME=openai/privacy-filter
MODEL_DEVICE=cpu                 # cpu | cuda | mps
MODEL_AGGREGATION=simple         # simple | first | average | max

# Storage backend: local | gcs
STORAGE_BACKEND=local
LOCAL_DATA_DIR=./data

# When STORAGE_BACKEND=gcs
GCS_BUCKET=
GCS_PREFIX=privacy-filter/

# Logging
LOG_LEVEL=INFO
