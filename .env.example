# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_NAME=openai/privacy-filter
MODEL_DEVICE=cpu                 # cpu | cuda | mps
MODEL_AGGREGATION=simple         # simple | first | average | max

# ── Storage backend ───────────────────────────────────────────────────────────
# Set STORAGE_BACKEND=gcs to enable Google Cloud Storage.
# Uploaded files → gs://tanuh-bcd-bucket/privacy-app/uploads/<job_id>__<filename>
# Redacted files → gs://tanuh-bcd-bucket/privacy-app/redacted/<job_id>__redacted.<ext>
STORAGE_BACKEND=gcs
LOCAL_DATA_DIR=./data

# GCS target (matches tanuh-bcd-bucket / privacy-app folder)
GCS_BUCKET=tanuh-bcd-bucket
GCS_PREFIX=privacy-app

# ── GCS Authentication ────────────────────────────────────────────────────────
# Priority 1: dedicated GCS service account (tanuh-bcd-application2)
# Copy gcs-service-account.json from NHCX_HACKATHON and set path here.
GCS_CREDENTIALS_JSON=gcs-service-account.json

# Priority 2: shared / Vertex SA (fallback if GCS_CREDENTIALS_JSON not found)
# Copy gcp-service-account.json from NHCX_HACKATHON and set path here.
GOOGLE_APPLICATION_CREDENTIALS=gcp-service-account.json

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
PROJECT_ID=tanuh-bcd-questionnaire
REGION=global
ENDPOINT=aiplatform.googleapis.com

# ── Secret key ────────────────────────────────────────────────────────────────
SECRET_KEY=<your-secret-key>

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
